          "elType": "widget",
          "widgetType": "html",
          "settings": {
            "html": "<!-- FLOORS AREN'T A SIDE JOB + SCHEDULE FORM -->\n<section id=\"schedule\">\n  <div class=\"wrap\">\n    <div class=\"side-job\">\n      <div class=\"left\">\n        <h2>Floors and Carpet Aren't a Side Job. They're the Whole Job.</h2>\n        <div class=\"team-photo\" style=\"margin-top:24px\">\n          <img src=\"images/midland%20floor%20team.png\" alt=\"The Midland Floor Care team\" loading=\"lazy\">\n        </div>\n      </div>\n\n      <aside class=\"form-card\">\n        <h3>Schedule a visit here.</h3>\n        <p class=\"sub\">Free site evaluation. No pressure, no obligation.</p>\n        <form onsubmit=\"event.preventDefault(); alert('Thanks! A Midland tech will reach out within 1 business hour.');\">\n          <div class=\"row\"><label for=\"fname\">Name</label><input id=\"fname\" type=\"text\" required placeholder=\"Jane Doe\"></div>\n          <div class=\"row\"><label for=\"phone\">Phone</label><input id=\"phone\" type=\"tel\" required placeholder=\"(240) 555-0100\"></div>\n          <div class=\"row\">\n            <label>Choose a service</label>\n            <div class=\"radios\">\n              <label><input type=\"radio\" name=\"svc\" value=\"floor\"> Floor Cleaning</label>\n              <label><input type=\"radio\" name=\"svc\" value=\"carpet\"> Carpet Cleaning</label>\n              <label><input type=\"radio\" name=\"svc\" value=\"commercial\"> Commercial Care</label>\n            </div>\n          </div>\n          <div class=\"row\">\n            <label>Do you require emergency service?</label>\n            <div class=\"radios\">\n              <label><input type=\"radio\" name=\"emerg\" value=\"yes\"> Yes</label>\n              <label><input type=\"radio\" name=\"emerg\" value=\"no\"> No</label>\n            </div>\n          </div>\n          <div class=\"row\"><label for=\"zip\">Zip Code</label><input id=\"zip\" type=\"text\" required placeholder=\"20878\"></div>\n          <p class=\"help\">You'll be redirected to our pricing page along with an option to schedule a site visit.</p>\n          <button class=\"btn btn--block btn--lg\" type=\"submit\">Submit</button>\n        </form>\n        <div class=\"alt\">\n          Or call us right now:\n          <a href=\"tel:2405329097\">(240) 532-9097</a>\n        </div>\n      </aside>\n    </div>\n  </div>\n</section>"
          },
