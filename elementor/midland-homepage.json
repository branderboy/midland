          "settings": {
            "html": "<!-- HERO -->\n<section class=\"hero\">\n  <div class=\"bg\" aria-hidden=\"true\"></div>\n  <div class=\"wrap\">\n    <div class=\"chip-row\">\n      <span>Carpet</span><span>Hardwood</span><span>Tile</span><span>Concrete</span><span>Commercial</span>\n    </div>\n    <h1>Professional Floor &amp; Carpet Care in DC, MD &amp; VA.</h1>\n    <p class=\"sub\">\n      Family-owned, locally operated. Trusted by DMV homeowners and facility managers for <b>carpet cleaning, hardwood refinishing, tile &amp; grout, upholstery, and full commercial floor care.</b> <span class=\"urgent\">Call for immediate availability.</span>\n    </p>\n    <div class=\"ctas\">\n      <a class=\"btn btn--xl\" href=\"tel:2405329097\">\ud83d\udcde Call now (240) 532-9097</a>\n      <span class=\"secondary\">or <a href=\"#schedule\"><u>schedule a free site visit \u2192</u></a></span>\n    </div>\n    <div class=\"reviews\">\n      <span class=\"stars\">\u2605\u2605\u2605\u2605\u2605</span>\n      <span><b>5.0 Google Rating</b> \u00b7 774+ DMV Clients</span>\n      <span><b>Fully Insured</b> \u00b7 COI on Demand</span>\n    </div>\n  </div>\n</section>"
