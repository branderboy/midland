            "html": "<!-- ABOUT (mint, intro) -->\n<section class=\"mint\" id=\"about\">\n  <div class=\"wrap-narrow about-strip\">\n    <span class=\"eyebrow\">About</span>\n    <h2 class=\"mt-12\">Midland Floor Care delivers.</h2>\n    <p class=\"lede mt-18\">\n      Family-owned, serving DC, Maryland, and Virginia. From Bethesda homeowners pressing for family visits to Arlington property managers needing a 40K sq ft office cleaned overnight and same-play-book show-up on time, we do the work right and leave better than we found it.\n    </p>\n    <div class=\"mt-24\" style=\"display:flex;gap:12px;justify-content:center;flex-wrap:wrap\">\n      <a class=\"btn\" href=\"#schedule\">Schedule a Visit</a>\n      <a class=\"btn\" href=\"tel:2405329097\" style=\"background:#FFF;color:var(--green-deep);border-color:var(--green)\">\ud83d\udcde (240) 532-9097</a>\n    </div>\n  </div>\n</section>"
