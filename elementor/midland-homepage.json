          "id": "54668ce9",
          "elType": "widget",
          "widgetType": "html",
          "settings": {
            "html": "<!-- TESTIMONIALS -->\n<section class=\"testi\" id=\"testimonials\">\n  <div class=\"wrap\">\n    <div class=\"sect-head\">\n      <span class=\"eyebrow\" style=\"color:var(--green)\">Testimonials</span>\n      <h2>Our Happy Clients.</h2>\n      <p class=\"lede\">\n        We believe our clients' testimonials speak louder than our marketing. Here's what DMV homeowners and facility managers say about working with us.\n      </p>\n    </div>\n    <div class=\"testi-grid\">\n      <div class=\"testi-card\">\n        <span class=\"stars\">\u2605\u2605\u2605\u2605\u2605</span>\n        <blockquote>\"Very professional. Knowledgeable and willing to educate. Will refer Midland to anyone that needs carpet cleaning and repair soon to come.\"</blockquote>\n        <div class=\"who\"><div class=\"av\">PB</div><div><b>Patricia B.</b><span>BUSINESS ADVISOR | BETHESDA</span></div></div>\n      </div>\n      <div class=\"testi-card\">\n        <span class=\"stars\">\u2605\u2605\u2605\u2605\u2605</span>\n        <blockquote>\"40K sq ft office cleaned overnight. No downtime, no excuses. We see the result, not the work. Exactly what we wanted from a vendor.\"</blockquote>\n        <div class=\"who\"><div class=\"av\">AM</div><div><b>Property Manager</b><span>CLASS A OFFICE, ARLINGTON</span></div></div>\n      </div>\n      <div class=\"testi-card\">\n        <span class=\"stars\">\u2605\u2605\u2605\u2605\u2605</span>\n        <blockquote>\"Carpet like new after 8 years of kids and pets. The team showed up on time and treated the place like their own.\"</blockquote>\n        <div class=\"who\"><div class=\"av\">SK</div><div><b>Sandy K.</b><span>BETHESDA</span></div></div>\n      </div>\n    </div>\n  </div>\n</section>"
          },
