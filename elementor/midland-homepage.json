            "html": "<!-- COMMERCIAL SERVICES -->\n<section>\n  <div class=\"wrap\">\n    <div class=\"sect-head\">\n      <h2>Commercial Services</h2>\n      <blockquote class=\"svc-pull center\" style=\"border-left: 0; padding-left: 0; margin: 12px auto 0; max-width: 56ch\">\n        \"40K sq ft office cleaned overnight. No downtime.\"\n        <cite>Arlington Property Manager</cite>\n      </blockquote>\n    </div>\n    <div class=\"svc-block reveal\" style=\"grid-template-columns: 1fr 1fr\">\n      <div>\n        <ul>\n          <li>Carpet Cleaning (after-hours)</li>\n          <li>Tile &amp; Grout Deep Clean</li>\n          <li>Hard Surface Floor Restoration (VCT, stone)</li>\n          <li>Concrete Polishing</li>\n          <li>Janitorial Services</li>\n          <li>Upholstery + Leather Cleaning</li>\n          <li>EPA-Approved Disinfecting</li>\n        </ul>\n        <a class=\"btn\" href=\"#schedule\">Get a commercial quote \u2192</a>\n      </div>\n      <div class=\"photo\">\n        <img src=\"images/office%20floor.png\" alt=\"Real Midland commercial office floor cleaning in DMV\" loading=\"lazy\">\n      </div>\n    </div>\n  </div>\n</section>"
