            "html": "<!-- NAV -->\n<header class=\"nav\">\n  <div class=\"inner\">\n    <a href=\"/\" class=\"logo\" aria-label=\"Midland Floor Care home\">\n      <img src=\"images/midland-small-logo.png\" alt=\"Midland Floor Care\">\n    </a>\n    <nav class=\"primary\">\n      <ul>\n        <li><a href=\"#about\">About</a></li>\n        <li><a href=\"#schedule\">Quote</a></li>\n        <li><a href=\"#services\">Services</a></li>\n        <li><a href=\"#faq\">FAQ</a></li>\n        <li><a href=\"#testimonials\">Clients</a></li>\n        <li><a href=\"#footer\">Reach Us</a></li>\n      </ul>\n    </nav>\n    <div class=\"nav-cta\">\n      <a class=\"phone\" href=\"tel:2405329097\">(240) 532-9097</a>\n      <a class=\"btn\" href=\"#schedule\" style=\"padding:10px 18px;font-size:12px\">Schedule Visit</a>\n    </div>\n  </div>\n</header>"
