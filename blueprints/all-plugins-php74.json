{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "meta": {
        "title": "Midland \u2014 all 11 plugins (PHP 7.4 compat check)",
        "description": "Same as all-plugins-git.json but pinned to PHP 7.4 to verify the declared Requires PHP: 7.4 floor (e.g. the Smart CRM str_contains->strpos fix). If any plugin used an 8.0+ construct it would parse-error/fatal here.",
        "author": "midland"
    },
    "landingPage": "/wp-admin/plugins.php",
